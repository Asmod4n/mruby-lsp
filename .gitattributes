# Build-bumped / generated files: on merge, ALWAYS keep our side — never conflict.
#
# These are regenerated by `rake` (the deliberate `rake bump:*` version tasks
# and recorded mtimes), so an incoming version never needs to win. They use the
# `ours` merge driver, which keeps the current branch's copy on a merge conflict.
# (The vendored-gem manifest is no longer tracked — it is generated into the
# .vsix stage at package time, not committed.)
#
# The `ours` driver must be registered once per clone:
#   git config merge.ours.driver true
# The Claude Code SessionStart hook (.claude/settings.json) does this for
# cloud/agent sessions; set it by hand in a clone that needs it.
lib/mruby_lsp/version.rb                          merge=ours
vendor/value_bridge/lib/value_bridge/version.rb   merge=ours
share/mtimes.json                                 merge=ours

# package.json carries hand-edited content (commands, capabilities), not only the
# bumped "version" field. merge=ours keeps OUR WHOLE file on a conflict, so make
# real package.json edits on the side you merge INTO; an incoming package.json is
# dropped on conflict. That's acceptable here because real edits arrive as applied
# patches/commits on the branch you keep, while the only divergence in practice is
# the auto-bumped version.
editors/vscode/package.json                       merge=ours
