# mruby build output (our gem + prism land here at build time)
/mruby/build/
# the mruby clone itself is fetched at setup time, not vendored
/mruby/
# generated indexes / compile db (regenerated by rake; cleaned by rake clean)
mruby-lsp-index.json
compile_commands.json
mruby.vcxproj
# extension packaging (path is editors/vscode, regenerated by rake)
editors/vscode/node_modules/
editors/vscode/out/
editors/vscode/*.vsix
# gem build output
/pkg/
# fuzzing artifacts — crash inputs, growing corpus, sanitizer logs.
# Keep fuzz/*.dict, harnesses, and the SEED corpus (fuzz/corpus-seed/);
# ignore the live corpus and findings.
/fuzz/corpus/
/fuzz/crash-*
/fuzz/leak-*
/fuzz/timeout-*
/fuzz/oom-*
/fuzz/*.log
/fuzz/fuzz_parser
/fuzz/fuzz_frame
.mruby-lsp/
dist/
# wrapper build lockfile must never be committed into the gem/tree.
# Primary defense is MRuby::Lockfile.disable in share/wrapper_build_config.rb;
# this is the documented backstop (docs/GOTCHAS.md).
share/*.rb.lock
